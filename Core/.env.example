# .env.template / .env.example
# Local-only environment configuration. Copy to .env and edit.
# Never commit your real .env. Templates are the source of truth.
# 
# Security hygiene:
# - .env is ignored via .gitignore: keep it local-only.
# - Rotate GUARDIAN_API_KEY regularly; prefer short-lived tokens.
# - Never ship VITE_GUARDIAN_API_KEY in any hosted/public build.

# --- Core runtime ---
ENV=development
LOG_LEVEL=INFO
DEBUG=true
PORT=8888

# --- Auth boundary ---
# local  -> static X-API-Key auth is allowed (localhost/dev only)
# remote -> static API keys are rejected; session/JWT is required
GUARDIAN_AUTH_MODE=local
# Backend auth secret. Use a long random value and rotate frequently.
GUARDIAN_API_KEY=58e96127c5131719d9a040eda0681be0c9891be30dd27305cce2fd1bea4d46b1
# Optional bootstrap secret for the canonical local owner account.
# When unset, startup still creates the local owner row but no guessable login
# credential is seeded.
GUARDIAN_BOOTSTRAP_PASSWORD=
# Local-only browser key injection. Mirror the backend key ONLY when running
# on localhost/trusted dev builds; leave empty for anything public or hosted.
# Example: VITE_GUARDIAN_API_KEY=${GUARDIAN_API_KEY}
VITE_GUARDIAN_API_KEY=58e96127c5131719d9a040eda0681be0c9891be30dd27305cce2fd1bea4d46b1
# Session/JWT signing secret (required when GUARDIAN_AUTH_MODE=remote)
GUARDIAN_SESSION_SECRET=replace-with-long-random-secret
GUARDIAN_JWT_SECRET=
GUARDIAN_DEV_MODE=false
# Backend CORS allowlist (include browser + Tauri desktop origins for local dev).
GUARDIAN_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,tauri://localhost,http://tauri.localhost,https://tauri.localhost
# Desktop runtime defaults (used by Tauri shell; can be overridden in Settings > Connection).
CODEXIFY_DESKTOP_BACKEND_URL=http://100.109.4.57:8888
CODEXIFY_DESKTOP_SHARE_BASE_URL=http://100.109.4.57:5173

# --- Database ---
# Compose-local Postgres contract. Keep these values aligned with docker-compose.yml.
POSTGRES_USER=codexify
POSTGRES_PASSWORD=codexify
POSTGRES_DB=Codexify
PGHOST=db
PGPORT=5432
PGUSER=codexify
PGPASSWORD=codexify
PGDATABASE=Codexify
DATABASE_URL=postgresql://codexify:codexify@db:5432/Codexify
GUARDIAN_DATABASE_URL=postgresql+psycopg://codexify:codexify@db:5432/Codexify
GUARDIAN_DB_URL=postgresql://codexify:codexify@db:5432/Codexify
GUARDIAN_DB_PATH=__DISABLE_SQLITE__

# --- Local LLM (Ollama/OpenAI-compatible) ---
# NOTE: LLM_PROVIDER must be a single provider id (not a comma-separated list).
LLM_PROVIDER=local
ALLOW_CLOUD_PROVIDERS=false
CODEXIFY_LOCAL_ONLY_MODE=true
CODEXIFY_EGRESS_ALLOWLIST=
LLM_MODEL=library2/ministral-3:8b
# Primary local Ollama base URL used by chat/provider catalog.
# For Dockerized backend on macOS, prefer host.docker.internal over localhost.
LOCAL_BASE_URL=http://host.docker.internal:11434
# Optional fallback bridge URL used when LOCAL_BASE_URL points at loopback.
LOCAL_DOCKER_FALLBACK_BASE_URL=http://host.docker.internal:11434
LOCAL_API_KEY=local
LOCAL_CHAT_MODEL=gemma4-e4b-hauhau:latest
VAULTNODE_BASE_URL=

# --- Embeddings ---
EMBEDDER_PROVIDER=local
# Supported: local, local_api (alias), openai, plus configured registry-backed providers.
EMBEDDING_BACKEND=local
EMBEDDING_DIM=128
EMBEDDING_MODEL=
LOCAL_EMBED_MODEL=/models/bge-large-en-v1.5

# --- Cloud providers (optional; set ALLOW_CLOUD_PROVIDERS=true) ---
# Also set CODEXIFY_LOCAL_ONLY_MODE=false and include the target provider in
# CODEXIFY_EGRESS_ALLOWLIST (for example: openai,groq,minimax).
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBED_MODEL=
OPENAI_EMBEDDING_MODEL=
GROQ_API_KEY=
GROQ_BASE_URL=
MINIMAX_API_KEY=
MINIMAX_API_BASE=
MINIMAX_MODEL=
MINIMAX_TIMEOUT_SECONDS=60
ANTHROPIC_API_KEY=
GENAI_API_KEY=

# --- Neo4j ---
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=replace-with-neo4j-password

# --- Integrations (optional) ---
NOTION_API_KEY=
DISCORD_BOT_TOKEN=
GITHUB_TOKEN=

# --- Google OAuth connector (node-local default, relay optional) ---
# Connector policy: node_local | hybrid | relay_only
GOOGLE_CONNECTOR_MODE=hybrid
# Node-local OAuth app credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=http://localhost:8888/api/connect/google/callback
# Optional relay broker mode
GOOGLE_RELAY_BROKER_URL=
GOOGLE_RELAY_AUDIENCE=
# Token encryption key (Fernet key). Example generation:
# python - <<'PY'
# from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
# PY
GUARDIAN_OAUTH_TOKEN_ENCRYPTION_KEY=

# --- Beta-1 stabilization quarantine (optional) ---
# Set to true to mount only the Beta-1 core surface:
# chat + migration + document upload/embedding (+ health/admin/projects/threads).
CODEXIFY_BETA_CORE_ONLY=false
# Fine-grained route toggles (used when CODEXIFY_BETA_CORE_ONLY=false)
CODEXIFY_ENABLE_CONNECTOR_ROUTES=true
CODEXIFY_ENABLE_FEDERATION_ROUTES=true
CODEXIFY_ENABLE_FLOW_ROUTES=true
CODEXIFY_ENABLE_TOOL_ROUTES=true
CODEXIFY_ENABLE_COMMAND_BUS_ROUTES=true
CODEXIFY_ENABLE_CRON_ROUTES=true
CODEXIFY_ENABLE_WEBSOCKET_ROUTES=true
CODEXIFY_ENABLE_MEDIA_GENERATION_ROUTES=true
CODEXIFY_ENABLE_MEDIA_TTS_ROUTES=true

# --- Workers / eventing ---
ENABLE_OUTBOX=true
ENABLE_CONNECTOR_WORKER=false

# --- Cache ---
CACHE_ENABLED=false

# --- Security / rate limiting (optional) ---
GUARDIAN_ENABLE_RATE_LIMITING=1
GUARDIAN_RATE_LIMITS=100/minute,1000/hour
GUARDIAN_ENABLE_SECURITY_HEADERS=1
GUARDIAN_CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;
