    "@tauri-apps/api": "^2.7.0",
    "axios": "^1.12.2",
    "clsx": "^2.1.1",
    "event-source-polyfill": "^1.0.27",
    "framer-motion": "^12.23.12",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.541.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-force-graph": "^1.48.1",
